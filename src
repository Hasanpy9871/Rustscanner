fn main() {
    print_banner();
    
    let args: Vec<String> = std::env::args().collect();
    
    if args.len() < 3 {
        println!("{}", "Usage: cargo run -- -t <target> [options]".yellow());
        println!();
        println!("Options:");
        println!("  -t <target>     Target IP or domain");
        println!("  -p <ports>      Ports to scan (comma-separated or range)");
        println!("  --no-nse        Skip NSE scripts");
        println!("  -o <format>     Output format (html, json, all)");
        println!();
        println!("Examples:");
        println!("  cargo run -- -t 192.168.1.1");
        println!("  cargo run -- -t scanme.nmap.org -p 22,80,443");
        println!("  cargo run -- -t 192.168.1.1 --no-nse");
        println!("  cargo run -- -t 192.168.1.1 -o html");
        return;
    }
    
    let mut target = String::new();
    let mut ports_list: Vec<u16> = Vec::new();
    let mut skip_nse = false;
    let mut output_format = "terminal";
    
    let mut i = 1;
    while i < args.len() {
        match args[i].as_str() {
            "-t" => {
                if i + 1 < args.len() {
                    target = args[i + 1].clone();
                    i += 1;
                }
            }
            "-p" => {
                if i + 1 < args.len() {
                    for part in args[i + 1].split(',') {
                        if let Ok(port) = part.parse::<u16>() {
                            ports_list.push(port);
                        } else if part.contains('-') {
                            let range: Vec<&str> = part.split('-').collect();
                            if range.len() == 2 {
                                if let (Ok(start), Ok(end)) = (range[0].parse::<u16>(), range[1].parse::<u16>()) {
                                    for port in start..=end {
                                        ports_list.push(port);
                                    }
                                }
                            }
                        }
                    }
                    i += 1;
                }
            }
            "--no-nse" => {
                skip_nse = true;
            }
            "-o" => {
                if i + 1 < args.len() {
                    output_format = args[i + 1].as_str();
                    i += 1;
                }
            }
            _ => {}
        }
        i += 1;
    }
    
    if target.is_empty() {
        println!("{}", "Error: No target specified".red());
        return;
    }
    
    println!("{}", format!("[*] Target: {}", target).cyan());
    
    if !skip_nse {
        if !check_nmap() {
            println!("{}", "Warning: Nmap not found, continuing without NSE scripts".yellow());
            skip_nse = true;
        }
    }
    
    if ports_list.is_empty() {
        ports_list = vec![21,22,23,25,53,80,111,139,443,445,3306,5432,5900,8080];
        println!("{}", "[*] Using default common ports list".dimmed());
    }
    
    println!("{}", format!("[*] Ports to scan: {} ports", ports_list.len()).cyan());
    
    let open_ports = scan_ports_multi(target.clone(), ports_list, 1000);
    
    if open_ports.is_empty() {
        println!("{}", "No open ports found".yellow());
        return;
    }
    
    let mut report = ScanReport::new(target.clone());
    report.open_ports = open_ports.clone();
    
    if !skip_nse {
        let nse_results = run_all_nse_scripts(&target, &open_ports);
        report.nse_summary = nse_results.clone();
        
        let deep_results = run_nmap_deep_scan(&target, &open_ports);
        for result in deep_results {
            report.nse_summary.push(result);
        }
    }
    
    for port in &mut report.open_ports {
        port.nse_results = report.nse_summary
            .iter()
            .filter(|r| r.output.contains(&port.port.to_string()))
            .cloned()
            .collect();
    }
    
    println!();
    println!("{}", "╔════════════════════════════════════════════════════════════════════════════════╗".cyan().bold());
    println!("{}", "                                SCAN COMPLETE                                      ".cyan().bold());
    println!("{}", "╚════════════════════════════════════════════════════════════════════════════════╝".cyan().bold());
    println!();
    println!("{}", format!("✓ Target: {}", report.target).green());
    println!("{}", format!("✓ Open ports: {}", report.open_ports.len()).green());
    
    if !skip_nse {
        let high_risk = report.nse_summary.iter().filter(|r| r.risk_level == "HIGH").count();
        println!("{}", format!("✓ Vulnerabilities found: {} (High: {})", report.nse_summary.len(), high_risk).green());
    }
    println!();
    
    if output_format == "html" || output_format == "all" {
        save_html_report(&report);
    }
    
    if output_format == "json" || output_format == "all" {
        let json_file = format!("rustscan_{}.json", chrono::Local::now().format("%Y%m%d_%H%M%S"));
        let json_data = serde_json::to_string_pretty(&report).unwrap();
        let mut file = File::create(&json_file).unwrap();
        file.write_all(json_data.as_bytes()).unwrap();
        println!("{}", format!("✓ JSON report saved: {}", json_file).green());
    }
}
