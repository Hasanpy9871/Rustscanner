//! RUSTSCANNER v2.0 - Professional Network Scanner
//! With Full Nmap NSE Integration

use colored::*;
use serde::{Serialize, Deserialize};
use std::net::{TcpStream, SocketAddr};
use std::time::Duration;
use std::process::Command;
use std::sync::{Arc, Mutex};
use std::thread;
use std::fs::File;
use std::io::Write;
use chrono;

#[derive(Debug, Serialize, Deserialize, Clone)]
struct ScanResult {
    port: u16,
    state: String,
    service: String,
    version: String,
    nse_results: Vec<NseResult>,
}

#[derive(Debug, Serialize, Deserialize, Clone)]
struct NseResult {
    script_name: String,
    output: String,
    risk_level: String,
}

#[derive(Debug, Serialize, Deserialize)]
struct ScanReport {
    target: String,
    timestamp: String,
    open_ports: Vec<ScanResult>,
    nse_summary: Vec<NseResult>,
}

impl ScanReport {
    fn new(target: String) -> Self {
        ScanReport {
            target,
            timestamp: chrono::Local::now().format("%Y-%m-%d %H:%M:%S").to_string(),
            open_ports: Vec::new(),
            nse_summary: Vec::new(),
        }
    }
}

fn print_banner() {
    println!();
    println!("{}", "╔════════════════════════════════════════════════════════════════════════════════╗".cyan().bold());
    println!("{}", "║                           RUSTSCANNER v2.0                                      ║".cyan().bold());
    println!("{}", "║                    Professional Network Scanner with NSE                        ║".cyan().bold());
    println!("{}", "╚════════════════════════════════════════════════════════════════════════════════╝".cyan().bold());
    println!();
}

fn check_nmap() -> bool {
    match Command::new("nmap").arg("--version").output() {
        Ok(output) => {
            if output.status.success() {
                let version = String::from_utf8_lossy(&output.stdout);
                let first_line = version.lines().next().unwrap_or("Nmap installed");
                println!("{}", format!("✓ Nmap found: {}", first_line).green());
                true
            } else {
                println!("{}", "✗ Nmap not found - Install with: sudo apt install nmap".yellow());
                false
            }
        }
        Err(_) => {
            println!("{}", "✗ Nmap not found - Install with: sudo apt install nmap".yellow());
            false
        }
    }
}

fn scan_port(target: &str, port: u16, timeout: u64) -> bool {
    let addr = format!("{}:{}", target, port);
    if let Ok(socket_addr) = addr.parse::<SocketAddr>() {
        TcpStream::connect_timeout(&socket_addr, Duration::from_millis(timeout)).is_ok()
    } else {
        false
    }
}

fn get_service_name(port: u16) -> String {
    match port {
        20 => "ftp-data".to_string(),
        21 => "ftp".to_string(),
        22 => "ssh".to_string(),
        23 => "telnet".to_string(),
        25 => "smtp".to_string(),
        53 => "dns".to_string(),
        80 => "http".to_string(),
        110 => "pop3".to_string(),
        111 => "rpcbind".to_string(),
        135 => "msrpc".to_string(),
        139 => "netbios-ssn".to_string(),
        143 => "imap".to_string(),
        443 => "https".to_string(),
        445 => "microsoft-ds".to_string(),
        993 => "imaps".to_string(),
        995 => "pop3s".to_string(),
        1433 => "mssql".to_string(),
        3306 => "mysql".to_string(),
        3389 => "rdp".to_string(),
        5432 => "postgresql".to_string(),
        5900 => "vnc".to_string(),
        6379 => "redis".to_string(),
        8080 => "http-proxy".to_string(),
        27017 => "mongodb".to_string(),
        _ => "unknown".to_string(),
    }
}

fn run_nse_script(target: &str, port: u16, script_name: &str) -> Option<NseResult> {
    let output = Command::new("nmap")
        .args([
            "-p", &port.to_string(),
            "--script", script_name,
            "-sV", "--script-timeout", "30s",
            "-oN", "-",
            target
        ])
        .output();
    
    match output {
        Ok(output) => {
            let stdout = String::from_utf8_lossy(&output.stdout);
            let stderr = String::from_utf8_lossy(&output.stderr);
            let full_output = format!("{}{}", stdout, stderr);
            
            let risk_level = if full_output.contains("VULNERABLE") || full_output.contains("CVE-") {
                "HIGH".to_string()
            } else if full_output.contains("WARNING") || full_output.contains("possible") {
                "MEDIUM".to_string()
            } else if !full_output.is_empty() {
                "INFO".to_string()
            } else {
                "NONE".to_string()
            };
            
            if !full_output.is_empty() {
                Some(NseResult {
                    script_name: script_name.to_string(),
                    output: full_output,
                    risk_level,
                })
            } else {
                None
            }
        }
        Err(_) => None,
    }
}

fn run_all_nse_scripts(target: &str, ports: &[ScanResult]) -> Vec<NseResult> {
    let mut all_results = Vec::new();
    
    println!("{}", "[*] Running NSE vulnerability scripts...".yellow());
    
    for port in ports {
        let script_names = match port.service.as_str() {
            "http" | "https" => {
                if port.port == 80 || port.port == 443 {
                    vec!["vulners", "http-enum", "http-title", "http-headers"]
                } else {
                    vec!["vulners", "http-enum"]
                }
            }
            "ssh" => vec!["vulners", "ssh-auth-methods", "ssh2-enum-algos"],
            "ftp" => vec!["vulners", "ftp-anon"],
            "mysql" => vec!["vulners", "mysql-info"],
            "microsoft-ds" | "netbios-ssn" => vec!["vulners", "smb-vuln-*"],
            "rdp" => vec!["vulners", "rdp-vuln-ms12-020"],
            "vnc" => vec!["vulners", "vnc-info"],
            _ => vec!["vulners"],
        };
        
        for script_name in script_names {
            print!("{}", format!("  ▶ Running {} on port {}...", script_name, port.port).dimmed());
            if let Some(result) = run_nse_script(target, port.port, script_name) {
                println!("{}", format!(" [{}]", result.risk_level).cyan());
                all_results.push(result);
            } else {
                println!(" {}", "[No findings]".dimmed());
            }
        }
    }
    
    all_results
}

fn run_nmap_deep_scan(target: &str, ports: &[ScanResult]) -> Vec<NseResult> {
    let mut results = Vec::new();
    
    println!("{}", "[*] Running Nmap full vulnerability scan...".yellow());
    
    let port_str: Vec<String> = ports.iter().map(|p| p.port.to_string()).collect();
    let ports_arg = port_str.join(",");
    
    if ports_arg.is_empty() {
        println!("{}", "  No open ports found, skipping deep scan".dimmed());
        return results;
    }
    
    let output = Command::new("nmap")
        .args([
            "-p", &ports_arg,
            "--script", "vulners,vuln,exploit,default,safe",
            "-sV",
            "--script-timeout", "60s",
            "-oN", "-",
            target
        ])
        .output();
    
    match output {
        Ok(output) => {
            let stdout = String::from_utf8_lossy(&output.stdout);
            let stderr = String::from_utf8_lossy(&output.stderr);
            let full_output = format!("{}{}", stdout, stderr);
            
            for line in full_output.lines() {
                if line.contains("VULNERABLE") || line.contains("CVE-") {
                    results.push(NseResult {
                        script_name: "vulnerability".to_string(),
                        output: line.to_string(),
                        risk_level: "HIGH".to_string(),
                    });
                } else if line.contains("WARNING") {
                    results.push(NseResult {
                        script_name: "warning".to_string(),
                        output: line.to_string(),
                        risk_level: "MEDIUM".to_string(),
                    });
                }
            }
            
            let nmap_file = format!("nmap_scan_{}.txt", chrono::Local::now().format("%Y%m%d_%H%M%S"));
            let mut file = File::create(&nmap_file).unwrap();
            file.write_all(full_output.as_bytes()).unwrap();
            println!("{}", format!("✓ Full Nmap scan saved: {}", nmap_file).green());
        }
        Err(e) => {
            println!("{}", format!("  Error running Nmap: {}", e).red());
        }
    }
    
    results
}

fn scan_ports_multi(target: String, ports: Vec<u16>, timeout: u64) -> Vec<ScanResult> {
    let results = Arc::new(Mutex::new(Vec::new()));
    let mut handles = vec![];
    
    println!("{}", format!("[*] Scanning {} ports on {}...", ports.len(), target).yellow());
    
    for port in ports {
        let target_clone = target.clone();
        let results_clone = Arc::clone(&results);
        
        let handle = thread::spawn(move || {
            if scan_port(&target_clone, port, timeout) {
                let service = get_service_name(port);
                println!("{}", format!("   Port {} ({}) is OPEN", port, service).green());
                let result = ScanResult {
                    port,
                    state: "open".to_string(),
                    service: service.clone(),
                    version: "-".to_string(),
                    nse_results: Vec::new(),
                };
                let mut results_guard = results_clone.lock().unwrap();
                results_guard.push(result);
            }
        });
        handles.push(handle);
    }
    
    for handle in handles {
        let _ = handle.join();
    }
    
    let final_results = results.lock().unwrap().clone();
    final_results
}

fn save_html_report(report: &ScanReport) -> String {
