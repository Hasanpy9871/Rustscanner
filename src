        report.target.replace(".", "_"),
        chrono::Local::now().format("%Y%m%d_%H%M%S")
    );
    
    let mut ports_html = String::new();
    for port in &report.open_ports {
        let nse_summary: String = port.nse_results.iter()
            .map(|r| format!("<div class='risk-{}'>{}</div>", 
                match r.risk_level.as_str() {
                    "HIGH" => "high",
                    "MEDIUM" => "medium",
                    _ => "info",
                },
                r.output))
            .collect();
        
        ports_html.push_str(&format!("
            <div class='port-card'>
                <div class='port-header'>
                    <span class='port-number'>📡 {}</span>
                    <span class='service-name'>{}</span>
                </div>
                <div class='port-details'>
                    <div class='nse-results'>{}</div>
                </div>
            </div>", port.port, port.service, nse_summary));
    }
    
    let mut vulns_html = String::new();
    for vuln in &report.nse_summary {
        vulns_html.push_str(&format!("
            <div class='vulnerability {}'>
                <div class='vuln-name'> {}</div>
                <div class='vuln-output'>{}</div>
            </div>",
            match vuln.risk_level.as_str() {
                "HIGH" => "critical",
                "MEDIUM" => "high",
                _ => "info",
            },
            vuln.script_name,
            vuln.output
        ));
    }
    
    let html_content = format!(r#"<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>RustScanner Report - {target}</title>
    <style>
        body {{ font-family: monospace; background: #0a0e27; color: #00ffcc; padding: 20px; }}
        .container {{ max-width: 1300px; margin: auto; }}
        h1 {{ color: #00ffcc; border-left: 4px solid #00ffcc; padding-left: 20px; }}
        h2 {{ color: #ff9933; margin-top: 30px; border-bottom: 1px solid #333; padding-bottom: 10px; }}
        .stats {{ display: flex; gap: 20px; margin: 20px 0; }}
        .stat-card {{ background: rgba(0,0,0,0.4); padding: 20px; border-radius: 12px; text-align: center; flex: 1; }}
        .stat-number {{ font-size: 2em; color: #00ffcc; font-weight: bold; }}
