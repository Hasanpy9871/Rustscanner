        .port-header {{ background: rgba(0,255,204,0.1); padding: 15px; font-weight: bold; }}
        .port-number {{ color: #00ffcc; }}
        .service-name {{ color: #ffcc00; margin-left: 15px; }}
        .port-details {{ padding: 15px; }}
        .vulnerability {{ background: rgba(0,0,0,0.3); margin: 10px 0; padding: 15px; border-radius: 8px; border-left: 4px solid #ff3366; }}
        .critical {{ border-left-color: #ff0000; background: rgba(255,0,0,0.1); }}
        .high {{ border-left-color: #ff6600; background: rgba(255,102,0,0.1); }}
        .footer {{ text-align: center; padding: 30px; color: #666; margin-top: 40px; border-top: 1px solid #333; }}
    </style>
</head>
<body>
<div class="container">
    <h1> RustScanner v2.0 Security Report</h1>
    
    <div class="stats">
        <div class="stat-card"><div class="stat-number">{target}</div><div>Target</div></div>
        <div class="stat-card"><div class="stat-number">{ports_count}</div><div>Open Ports</div></div>
        <div class="stat-card"><div class="stat-number">{vuln_count}</div><div>Vulnerabilities</div></div>
    </div>
    
    <h2> Open Ports & NSE Results</h2>
    {ports_html}
    
    <h2> Vulnerability Summary</h2>
    {vulns_html}
    
    <div class="footer">
        <p>Generated by RustScanner v2.0 | Powered by Nmap NSE</p>
        <p> {timestamp}</p>
